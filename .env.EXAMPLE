# App version
VERSION=latest

# Change the path where the servers files and mods will be stored on your server
STORAGE_PATH=/home/armaservermanager/storage

# (OPTIONAL) Path to a directory where application config and auto-generated secrets are stored.
# Defaults to ./config (the directory alongside docker-compose.yml)
# Docker users can customize this if needed
# CONFIG_PATH=./config

# Username and password for accessing the web interface
# AUTH_USERNAME is optional; defaults to 'admin' if not set
# AUTH_PASSWORD is optional; auto-generated on first run and printed to the startup log
# Uncomment and set these if you want to override the defaults
# AUTH_USERNAME=admin
# AUTH_PASSWORD=your-password

# Database settings. Make sure to change the password and root password
MYSQL_DB_NAME=armaservermanager_db
MYSQL_DB_URL=jdbc:mysql://localhost:3306/armaservermanager_db
# For Windows, use the following URL instead:
# MYSQL_DB_URL=jdbc:mysql://db:3306/armaservermanager_db
MYSQL_USER=armaservermanager
MYSQL_PASSWORD=example
MYSQL_ROOT_PASSWORD=change_me

# Steam API key, needed for Steam Workshop interaction.
# Generated with https://steamcommunity.com/dev/apikey.
STEAM_API_KEY=

# JWT secret
# Used for creating JSON web tokens for app authentication.
# Optional; auto-generated on first run and persisted to config/secrets.properties
# Uncomment and set this if you want to override the generated value
# JWT_SECRET=

# Database encryption secret used for encrypting the Steam account password inside the database.
# Optional; auto-generated on first run and persisted to config/secrets.properties
# If not set, Steam account passwords will be stored in plain text
# Uncomment and set this if you want to override the generated value or provide your own AES-256 key
# DATABASE_ENCRYPTION_SECRET=

# Set the right Timezone from https://en.wikipedia.org/wiki/List_of_tz_database_time_zones, example Europe/London , US/Pacific , etc
TIMEZONE=
